# apps3k common workflow — environment template (illustrative; this file is committed).
#
# Secrets live in 1Password — never put real secret VALUES here.
# The live `.env` is a 1Password "local-env-file" (a FIFO / named pipe) that
# resolves these refs on read while 1Password is unlocked. See
# docs/agents/secrets.md for the mechanism and the per-repo setup.
#
# Standard: a repo's `.env` contains EXACTLY ONE variable —
# OP_SERVICE_ACCOUNT_TOKEN — pointing at a 1Password service account scoped to
# just this repo's vault(s) (least privilege). Once it is present, `op` runs
# non-interactively, so every other secret is read on demand with
# `op read` / `op run` / `op inject` and need NOT be listed here.

OP_SERVICE_ACCOUNT_TOKEN=op://<repo-vault>/<service-account-item>/credential

# ── GrowthBook (only for repos with feature flags) — these are NOT persistent
# `.env` vars under the one-token standard. Read them at build/run time from
# 1Password (e.g. `op run -- <cmd>` / `op read`): the SDK key lives in this
# repo's vault, the API host is gb-api.apps3k.com, and client-exposed builds
# need the framework public prefix (PUBLIC_GROWTHBOOK_* for Astro/Vite,
# NEXT_PUBLIC_GROWTHBOOK_* for Next.js). See docs/feature-flags.md.

# ─────────────────────────────────────────────────────────────────────────────
# Orchid (the app). Self-hosters set these as real env vars (e.g. Coolify UI,
# docker-compose env, or a plain .env). apps3k devs may resolve them via 1Password.
# Create the GitHub App from /setup (it ships a manifest) — that yields the App id,
# private key, client id/secret, and webhook secret below. See docs/setup.md.

# Postgres connection (docker-compose sets this automatically for the bundle).
DATABASE_URL=postgres://orchid:orchid@db:5432/orchid

# Public base URL of this instance (used for OAuth callback + webhook URLs).
APP_URL=http://localhost:3000

# Session signing secret (generate: `openssl rand -base64 32`).
SESSION_SECRET=

# Optional: dedicated key for encrypting secrets at rest (AES-256-GCM): the GitHub App key + the
# BYOK provider keys. Falls back to SESSION_SECRET if unset. Generate: `openssl rand -base64 32`.
# To ROTATE it: stop the app, then run
#   APP_ENCRYPTION_KEY_OLD=<current> APP_ENCRYPTION_KEY=<new> pnpm key:rotate
# (re-encrypts all stored secrets), then restart with APP_ENCRYPTION_KEY=<new>.
# If you never set APP_ENCRYPTION_KEY, secrets were encrypted under SESSION_SECRET — use that
# value as APP_ENCRYPTION_KEY_OLD for the first rotation.
APP_ENCRYPTION_KEY=

# GitHub App (one App per self-hoster; data access + user-OAuth login).
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=          # PEM; for compose use a file/secret, not inline
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_WEBHOOK_SECRET=       # optional until webhooks (v2)

# Canonical template repo the hooks-overview + automation recipes compare against.
ORCHID_TEMPLATE_REPO=apps3k-com/workflow-template

# BYOK agent/hook auditor: comma-separated GitHub logins allowed to manage LLM provider keys and
# run audits (the "LLM admin" role). Empty/unset = nobody can (key management stays locked down).
ORCHID_LLM_ADMINS=

# Per-run cost ceiling (USD) for an audit. A free token preflight estimates the run; it is refused
# if the estimate exceeds this. Default 0.5.
ORCHID_AUDIT_MAX_USD=0.5

# ── shadcnstudio Pro (UI source of truth). BUILD/DEV-time ONLY: needed when
# pulling UI blocks via the shadcn CLI (see components.json → registries; the
# `@ss-*` namespaces expand ${EMAIL}/${LICENSE_KEY} into the registry request).
# Not needed to run the app. Resolve from 1Password; never commit the values.
# EMAIL = shadcnstudio account email · LICENSE_KEY = key from the billing page.
EMAIL=op://<repo-vault>/shadcnstudio/email
LICENSE_KEY=op://<repo-vault>/shadcnstudio/license_key
