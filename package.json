{
  "name": "orchid-dev-dashboard",
  "version": "1.1.1",
  "private": true,
  "packageManager": "pnpm@10.15.0",
  "description": "Orchid — open-source multi-repo & GitHub-Projects mission control",
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "check": "pnpm run lint && pnpm run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:dev": "prisma migrate dev",
    "docstring:coverage": "node scripts/docstring-coverage.mjs",
    "key:rotate": "node scripts/rotate-encryption-key.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@octokit/app": "^15.1.6",
    "@octokit/auth-app": "^7.1.5",
    "@octokit/core": "^6.1.4",
    "@octokit/graphql": "^8.2.1",
    "@octokit/oauth-app": "^7.1.6",
    "@octokit/rest": "^21.1.1",
    "@prisma/client": "^6.16.3",
    "@tanstack/react-query": "^5.62.7",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "graphile-worker": "^0.16.6",
    "jose": "^5.9.6",
    "js-yaml": "^4.1.0",
    "libsodium-wrappers": "0.7.15",
    "lucide-react": "^0.469.0",
    "next": "16.2.9",
    "radix-ui": "^1.6.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.54.2",
    "tailwind-merge": "^3.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "prisma": "^6.16.3",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.2.5",
    "typescript": "^5",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "overrides": {
      "postcss": "^8.5.10"
    }
  }
