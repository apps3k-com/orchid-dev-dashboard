{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "PROTECTED_BRANCH": "main",
    "WORKFLOW_REQUIRE_ISSUE_REF": "true"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.claude/hooks/branch-name-guard.sh\"",
            "timeout": 10,
            "statusMessage": "Validating branch name..."
          },
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.claude/hooks/commit-guard.sh\"",
            "timeout": 10,
            "statusMessage": "Checking branch protection..."
          },
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.claude/hooks/merge-guard.sh\"",
            "timeout": 10,
            "statusMessage": "Checking merge target..."
          },
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.claude/hooks/pr-merge-guard.sh\"",
            "timeout": 10,
            "statusMessage": "PR merge is owner-only..."
          },
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.claude/hooks/pr-validate.sh\"",
            "timeout": 10,
            "statusMessage": "Validating PR requirements..."
          },
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.claude/hooks/push-guard.sh\"",
            "timeout": 10,
            "statusMessage": "Checking push target..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.claude/hooks/pr-coderabbit-loop.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.claude/hooks/session-init.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.claude/hooks/coderabbit-loop-guard.sh\"",
            "timeout": 20
          },
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.claude/hooks/self-review.sh\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
