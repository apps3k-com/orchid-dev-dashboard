// Orchid — Prisma schema.
// Postgres is a CACHE of GitHub state (refreshed by the worker) plus APP state
// (users/sessions/sync cursors) and SOURCE-OF-TRUTH-PROXY rows (drafts/audit) for
// the writes Orchid performs back to GitHub. GitHub remains authoritative after a
// write lands via PR. Models are added per increment; this initial slice covers
// orgs/repos and app/session state so the scaffold migrates and builds.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// A GitHub organization (or user) the installed App can manage. CACHE.
model Org {
  id             String    @id @default(cuid())
  githubId       Int       @unique // immutable GitHub account id; stable across renames — the upsert key
  login          String    @unique // mutable display handle (changes on rename)
  name           String?
  installationId Int?      @unique
  avatarUrl      String?
  repos          Repo[]
  projects       Project[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

/// A repository within a managed org. CACHE.
model Repo {
  id              String              @id @default(cuid())
  githubId        Int                 @unique // immutable GitHub repo id; stable across rename/transfer — the upsert key
  org             Org                 @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId           String
  name            String
  nameWithOwner   String              @unique // mutable (changes on rename/transfer)
  defaultBranch   String              @default("main")
  isArchived      Boolean             @default(false)
  isPrivate       Boolean             @default(false)
  url             String?
  pushedAt        DateTime?
  pulls           PullRequest[]
  automations     AutomationInstall[]
  hookStates      RepoHookState[]
  audits          RepoAudit[]
  auditBatchItems AuditBatchItem[]
  standards       RepoStandard[]
  modules         Module[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([orgId])
}

/// Orchid-side presentation metadata for a repo module. The module NAMES live in the repo's
/// `.github/modules.yaml` (and drive the label/dropdown sync); description + status are Orchid-only,
/// so they can be edited directly without a PR. APP.
model Module {
  id          String   @id @default(cuid())
  repo        Repo     @relation(fields: [repoId], references: [id], onDelete: Cascade)
  repoId      String
  name        String // matches a name in .github/modules.yaml
  description String   @default("")
  status      String   @default("active") // active | deprecated
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([repoId, name])
  @@index([repoId])
}

/// A cached open pull request (refreshed by the worker / on-demand). CACHE.
model PullRequest {
  id             String    @id @default(cuid())
  nodeId         String    @unique // immutable GitHub GraphQL node id
  repo           Repo      @relation(fields: [repoId], references: [id], onDelete: Cascade)
  repoId         String
  number         Int
  title          String
  url            String
  state          String // OPEN | CLOSED | MERGED
  isDraft        Boolean   @default(false)
  authorLogin    String?
  baseRef        String
  headRef        String?
  reviewDecision String? // APPROVED | CHANGES_REQUESTED | REVIEW_REQUIRED
  checksState    String? // SUCCESS | FAILURE | PENDING | ERROR
  mergeable      String? // MERGEABLE | CONFLICTING | UNKNOWN
  labels         String[]
  ghUpdatedAt    DateTime?
  syncedAt       DateTime  @default(now())

  @@unique([repoId, number])
  @@index([repoId])
  @@index([state])
}

/// A GitHub ProjectV2 owned by a managed org (cross-repo board). CACHE.
model Project {
  id               String        @id @default(cuid())
  nodeId           String        @unique // immutable GitHub GraphQL node id
  org              Org           @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId            String
  number           Int
  title            String
  url              String
  shortDescription String?
  closed           Boolean       @default(false)
  itemCount        Int           @default(0)
  items            ProjectItem[]
  ghUpdatedAt      DateTime?
  syncedAt         DateTime      @default(now())

  @@unique([orgId, number])
  @@index([orgId])
}

/// A cached ProjectV2 item (issue/PR/draft) with its Status column, for the per-project board. CACHE.
model ProjectItem {
  id          String    @id @default(cuid())
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  nodeId      String    @unique // immutable ProjectV2Item GraphQL node id
  type        String // ISSUE | PULL_REQUEST | DRAFT_ISSUE
  title       String
  url         String?
  number      Int?
  state       String? // OPEN | CLOSED | MERGED (issues/PRs)
  status      String? // Status single-select option name (null = no Status)
  priority    String? // Priority single-select option name, if the project has one
  assignees   String[]  @default([]) // assignee logins (GitHub caps at 10/item)
  labels      String[]  @default([]) // label names
  contentRepo String? // nameWithOwner of the item's source repo
  ghUpdatedAt DateTime?
  syncedAt    DateTime  @default(now())

  @@index([projectId])
}

/// An automation recipe provisioned into a repo (one row per repo + recipe). Orchid is the
/// index; the repo (managed header in the workflow file) is authoritative. APP/audit.
model AutomationInstall {
  id        String   @id @default(cuid())
  repo      Repo     @relation(fields: [repoId], references: [id], onDelete: Cascade)
  repoId    String
  recipeId  String
  version   Int      @default(1)
  state     String // pending_pr | installed | missing
  prUrl     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([repoId, recipeId])
  @@index([repoId])
}

/// Per-file drift of a repo's agent hooks (.claude/** and .codex/**) vs the canonical template,
/// compared by git blob SHA. One row per repo + path. CACHE.
model RepoHookState {
  id          String   @id @default(cuid())
  repo        Repo     @relation(fields: [repoId], references: [id], onDelete: Cascade)
  repoId      String
  path        String
  status      String // match | outdated | missing | extra
  repoSha     String?
  templateSha String?
  // A confirmed repo-specific customization is tied to the exact SHA pair it was confirmed for, so
  // any later change to the repo or template file re-flags the drift. Preserved across syncs.
  acknowledgedRepoSha     String?
  acknowledgedTemplateSha String?
  acknowledgedBy          String?
  acknowledgedAt          DateTime?
  syncedAt    DateTime @default(now())

  @@unique([repoId, path])
  @@index([repoId])
}

/// Per-standard Tier-0 compliance of a repo vs the apps3k workflow-template baseline
/// (`TIER0_STANDARDS`). One row per repo + standard key. CACHE.
model RepoStandard {
  id       String   @id @default(cuid())
  repo     Repo     @relation(fields: [repoId], references: [id], onDelete: Cascade)
  repoId   String
  key      String // StandardKey: security-scan | dependabot | codeowners | license | ...
  tier     Int      @default(0)
  status   String // present | missing
  syncedAt DateTime @default(now())

  @@unique([repoId, key])
  @@index([repoId])
}

/// A human who signs in via GitHub OAuth (gated to managed-org membership). APP.
model User {
  id        String    @id @default(cuid())
  githubId  Int       @unique
  login     String
  name      String?
  avatarUrl String?
  email     String?
  sessions  Session[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

/// A login session (httpOnly cookie carries the id). APP.
model Session {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

/// Singleton GitHub App credentials for this instance, created by the /setup manifest flow
/// (or seeded from env). Secrets are stored ENCRYPTED at rest (AES-256-GCM; key from
/// APP_ENCRYPTION_KEY or SESSION_SECRET). Exactly one row (id = 1). APP (config).
model AppConfig {
  id               Int      @id @default(1)
  appId            Int
  slug             String?
  clientId         String
  privateKeyEnc    String // encrypted PEM (iv:tag:ciphertext, base64)
  clientSecretEnc  String // encrypted OAuth client secret
  webhookSecretEnc String? // encrypted webhook secret (optional until webhooks/v2)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

/// Per-resource sync cursor/last-run bookkeeping for the worker. APP.
model SyncState {
  id        String    @id @default(cuid())
  resource  String    @unique // e.g. "pulls", "projects:<org>", "taxonomy:<repo>"
  cursor    String?
  lastRunAt DateTime?
  lastError String?
  updatedAt DateTime  @updatedAt
}

/// A BYOK LLM provider credential for the agent/hook auditor. The key is stored ENCRYPTED at rest
/// (AES-256-GCM via crypto.ts), exactly like AppConfig.*Enc — only the last-4 hint is ever shown.
/// Multiple labelled keys per provider; one is the default, and an audit can pick which to use. APP (config).
model ProviderKey {
  id              String    @id @default(cuid())
  provider        String // "anthropic" (openai/cursor are later phases)
  label           String    @default("default") // user-facing name; unique per provider
  keyEnc          String // encryptSecret(apiKey) — iv:tag:ciphertext, base64
  maskedHint      String    @db.VarChar(8) // last-4 of the key only ("…XXXX") — capped so the column can never hold key material
  status          String    @default("unchecked") // unchecked | valid | invalid | rate_limited
  isDefault       Boolean   @default(false) // used unless another key is chosen at audit time; DB enforces one default per provider via partial unique index
  lastValidatedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([provider, label])
  @@index([provider])
  // Note: partial unique index (provider WHERE isDefault=true) is in the migration SQL; Prisma doesn't natively support it
}

/// Instance-wide settings for a BYOK provider: the default model used for audits (kept separate from
/// the key so the model can change without replacing a key, and vice versa). APP (config).
model ProviderSettings {
  id           String   @id @default(cuid())
  provider     String   @unique // "anthropic"
  defaultModel String // selected model id from the provider's config map
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// One LLM-powered audit run of a repo's agent + hook configuration (BYOK auditor). APP/audit.
model RepoAudit {
  id               String          @id @default(cuid())
  repo             Repo            @relation(fields: [repoId], references: [id], onDelete: Cascade)
  repoId           String
  provider         String // "anthropic"
  model            String // e.g. "claude-sonnet-4-6"
  providerKeyId    String? // which ProviderKey ran this audit (traceability; null for pre-multikey runs)
  status           String          @default("pending") // pending | running | completed | failed
  commitSha        String? // default-branch head the audit ran against (reproducibility)
  score            Int? // overall config-health score 0..100
  summary          String? // overall assessment
  inputTokens      Int?
  outputTokens     Int?
  estimatedUsd     Decimal?        @db.Decimal(10, 4)
  error            String? // briefError() output on failure
  triggeredByLogin String? // who ran it
  findings         AuditFinding[]
  batchItem        AuditBatchItem?
  createdAt        DateTime        @default(now())
  completedAt      DateTime?

  @@index([repoId])
  @@index([status])
}

/// A single finding from a RepoAudit. APP/audit.
model AuditFinding {
  id             String    @id @default(cuid())
  audit          RepoAudit @relation(fields: [auditId], references: [id], onDelete: Cascade)
  auditId        String
  title          String
  severity       String // critical | high | medium | low | info
  category       String // redundancy | misconfiguration | security | optimization | inconsistency | missing | deprecated
  file           String
  lineHint       Int?
  evidence       String?
  rationale      String
  recommendation String
  autoFixable    Boolean   @default(false)
  proposedPatch  String? // full replacement file content for a fix PR (v1c)
  state          String    @default("open") // open | dismissed | pr_opened | resolved
  prUrl          String?
  createdAt      DateTime  @default(now())

  @@index([auditId])
}

/// A fleet-wide audit run: estimates then runs RepoAudit for many repos at once. APP/audit.
model AuditBatch {
  id                        String           @id @default(cuid())
  status                    String           @default("estimating") // estimating | estimated | running | completed | cancelled | failed
  force                     Boolean          @default(false) // re-audit even if the commit is unchanged
  triggeredByLogin          String?
  totalEstimatedUsd         Decimal?         @db.Decimal(10, 4)
  totalEstimatedInputTokens Int?
  repoCount                 Int
  auditCount                Int?
  skippedCount              Int?
  error                     String?
  items                     AuditBatchItem[]
  createdAt                 DateTime         @default(now())
  estimatedAt               DateTime?
  confirmedAt               DateTime?
  completedAt               DateTime?

  @@index([status])
}

/// One repo's line item within an AuditBatch (estimate decision + resulting RepoAudit). APP/audit.
model AuditBatchItem {
  id                   String     @id @default(cuid())
  batch                AuditBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  batchId              String
  repo                 Repo       @relation(fields: [repoId], references: [id], onDelete: Cascade)
  repoId               String
  decision             String     @default("pending") // pending | will_audit | skip_unchanged | skip_no_config | error
  estimatedInputTokens Int?
  estimatedUsd         Decimal?   @db.Decimal(10, 4)
  commitSha            String?
  lastAuditCommitSha   String?
  error                String?
  audit                RepoAudit? @relation(fields: [auditId], references: [id], onDelete: SetNull)
  auditId              String?    @unique
  createdAt            DateTime   @default(now())

  @@unique([batchId, repoId])
  @@index([batchId])
}

/// A dismissed Decision-Queue item, keyed by the item's dedupeKey. Dismissed items stay hidden
/// until the underlying state (and therefore the key) changes. APP.
model DecisionDismissal {
  id          String   @id @default(cuid())
  dedupeKey   String   @unique
  dismissedBy String
  dismissedAt DateTime @default(now())
}
